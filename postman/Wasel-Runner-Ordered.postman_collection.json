      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Update checkpoint status endpoint returns 200', function () {",
              "  if (pm.response.code === 403) pm.expect.fail('403 on status update. User is not admin/moderator.');",
              "  if (pm.response.code === 404) pm.expect.fail('404 status update: checkpoint does not exist.');",
              "  if (pm.response.code !== 200) pm.expect.fail(`Status update failed: ${pm.response.text()}`);",
              "});"
            ]
          }
        }
      ]
    },
