            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login-again status 200', function () {",
              "  if (pm.response.code !== 200) pm.expect.fail(`Login again failed: ${pm.response.text()}`);",
              "});",
              "const j = pm.response.json();",
              "if (j.accessToken) pm.environment.set('accessToken', j.accessToken);",
              "if (j.refreshToken) pm.environment.set('refreshToken', j.refreshToken);"
            ]
          }
        }
      ]
    },
    {
      "name": "06 Create Checkpoint",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{checkpointName}}\",\n  \"latitude\": 31.95,\n  \"longitude\": 35.22,\n  \"status\": \"open\",\n  \"description\": \"Runner create\",\n  \"region\": \"Ramallah\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/checkpoints",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "checkpoints"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Create checkpoint status 201', function () {",
              "  if (pm.response.code === 403) pm.expect.fail('403 on create checkpoint. Do SQL admin step, then login again.');",
              "  if (pm.response.code !== 201) pm.expect.fail(`Create checkpoint failed: ${pm.response.text()}`);",
              "});",
              "const j = pm.response.json();",
              "if (j.data && j.data.id) pm.environment.set('checkpointId', String(j.data.id));"
            ]
          }
        }
      ]
    },
    {
      "name": "07 Get Checkpoint by Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/checkpoints/{{checkpointId}}",
          "host": [
            "{{baseUrl}}"
