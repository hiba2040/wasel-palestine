      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Update checkpoint status 200', function () {",
              "  if (pm.response.code === 403) pm.expect.fail('403 on update checkpoint. Ensure admin role and re-login.');",
              "  if (pm.response.code === 404) pm.expect.fail('404 checkpoint missing.');",
              "  if (pm.response.code !== 200) pm.expect.fail(`Update failed: ${pm.response.text()}`);",
              "});"
            ]
          }
        }
      ]
    },
    {
