    {
      "name": "16 Delete Checkpoint",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/checkpoints/{{checkpointId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "checkpoints",
            "{{checkpointId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.environment.get('adminBlocked') === 'true') {",
              "  pm.test('Delete skipped (user not admin)', function () { pm.expect(true).to.eql(true); });",
              "} else {",
              "  pm.test('Delete status is 200', function () {",
              "    if (pm.response.code !== 200) pm.expect.fail(`Delete failed: ${pm.response.text()}`);",
