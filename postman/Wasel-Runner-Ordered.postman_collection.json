        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Get checkpoint by id status 200', function () {",
              "  if (pm.response.code === 404) pm.expect.fail('Checkpoint not found. It may have been deleted.');",
              "  if (pm.response.code !== 200) pm.expect.fail(`Get checkpoint failed: ${pm.response.text()}`);",
              "});"
            ]
          }
        }
      ]
    },
