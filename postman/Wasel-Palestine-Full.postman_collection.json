{
  "info": {
    "_postman_id": "8c4d938e-6f1b-44bb-9f64-9c6f1a6d2a11",
    "name": "Wasel Palestine Full API",
    "description": "Full collection for Wasel Palestine API: health, auth, checkpoints, routes, and admin SQL helper.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('email')) {",
          "  const ts = Date.now();",
          "  pm.environment.set('email', `osama_${ts}@mail.com`);",
          "}",
          "if (!pm.environment.get('password')) {",
          "  pm.environment.set('password', 'Pass123456!');",
          "}",
          "if (!pm.environment.get('name')) {",
          "  pm.environment.set('name', 'Osama User');",
          "}",
          "if (!pm.environment.get('checkpointName')) {",
          "  pm.environment.set('checkpointName', 'Checkpoint From Postman');",
          "}",
          "if (!pm.environment.get('sourceLat')) { pm.environment.set('sourceLat', '31.9454'); }",
          "if (!pm.environment.get('sourceLon')) { pm.environment.set('sourceLon', '35.2338'); }",
          "if (!pm.environment.get('destLat')) { pm.environment.set('destLat', '31.9564'); }",
          "if (!pm.environment.get('destLon')) { pm.environment.set('destLon', '35.1978'); }"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 - Health",
      "item": [
        {
          "name": "GET /",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.test('Has running message', function () {",
                  "  pm.expect(json.message).to.include('Wasel Palestine API is running');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "POST /api/v1/auth/register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{name}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Register success or already exists', function () {",
                  "  pm.expect([201, 400]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/auth/login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.accessToken) { pm.environment.set('accessToken', json.accessToken); }",
                  "if (json.refreshToken) { pm.environment.set('refreshToken', json.refreshToken); }",
                  "if (json.user && json.user.id) { pm.environment.set('userId', String(json.user.id)); }"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/v1/auth/me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "POST /api/v1/auth/refresh-token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh-token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "refresh-token"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Refresh status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.accessToken) { pm.environment.set('accessToken', json.accessToken); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Admin SQL Helper (Run in pgAdmin)",
      "item": [
        {
          "name": "INFO - Make Logged User Admin",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ""
              ]
            },
            "description": "Run this SQL in pgAdmin Query Tool before admin endpoints:\n\nUPDATE users\nSET role = 'admin'\nWHERE email = '{{email}}';"
          }
        }
      ]
    },
    {
      "name": "03 - Checkpoints",
      "item": [
        {
          "name": "GET /api/v1/checkpoints",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/checkpoints?page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "checkpoints"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "POST /api/v1/checkpoints (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{checkpointName}}\",\n  \"latitude\": 31.95,\n  \"longitude\": 35.22,\n  \"status\": \"open\",\n  \"description\": \"Created from Postman\",\n  \"region\": \"Ramallah\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/checkpoints",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "checkpoints"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Create checkpoint status is 201', function () {",
                  "  if (pm.response.code !== 201) {",
                  "    const msg = `Expected 201 but got ${pm.response.code}. If 403, run SQL admin step then login again. Response: ${pm.response.text()}`;",
                  "    pm.expect.fail(msg);",
                  "  }",
                  "});",
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.environment.set('checkpointId', String(json.data.id));",
                  "} else {",
                  "  pm.expect.fail('Checkpoint created but id was missing in response.');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/v1/checkpoints/:id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/checkpoints/{{checkpointId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "checkpoints",
                "{{checkpointId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const id = pm.environment.get('checkpointId');",
                  "pm.test('checkpointId exists', function () {",
                  "  if (!id) pm.expect.fail('checkpointId is empty. Run POST /api/v1/checkpoints (Admin) first.');",
                  "});",
                  "pm.test('Checkpoint exists', function () {",
                  "  if (pm.response.code === 404) {",
                  "    pm.expect.fail('Checkpoint not found (404). It may have been deleted. Re-create checkpoint then retry.');",
                  "  }",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "PUT /api/v1/checkpoints/:id (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{checkpointName}} Updated\",\n  \"latitude\": 31.951,\n  \"longitude\": 35.221,\n  \"description\": \"Updated from Postman\",\n  \"region\": \"Ramallah\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/checkpoints/{{checkpointId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "checkpoints",
                "{{checkpointId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const id = pm.environment.get('checkpointId');",
                  "pm.test('checkpointId exists', function () {",
                  "  if (!id) pm.expect.fail('checkpointId is empty. Create checkpoint first.');",
                  "});",
                  "pm.test('Update checkpoint success', function () {",
                  "  if (pm.response.code === 403) pm.expect.fail('403 Access denied. Make user admin in SQL, then login again.');",
                  "  if (pm.response.code === 404) pm.expect.fail('404 Checkpoint not found. It may have been deleted.');",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/v1/checkpoints/:id/status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/checkpoints/{{checkpointId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "checkpoints",
                "{{checkpointId}}",
                "status"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status endpoint returns existing checkpoint', function () {",
                  "  if (pm.response.code === 404) {",
                  "    pm.expect.fail('404 on /status: checkpoint was not found. Usually deleted too early. Create checkpoint again.');",
                  "  }",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST /api/v1/checkpoints/:id/status (Admin/Moderator)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"restricted\",\n  \"note\": \"Set from Postman\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/checkpoints/{{checkpointId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "checkpoints",
                "{{checkpointId}}",
                "status"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status update success', function () {",
                  "  if (pm.response.code === 403) pm.expect.fail('403 Access denied. Update user role to admin/moderator and login again.');",
                  "  if (pm.response.code === 404) pm.expect.fail('404 checkpoint not found. It was likely deleted before this request.');",
                  "  if (pm.response.code === 400) pm.expect.fail(`400 bad request: ${pm.response.text()}`);",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/v1/checkpoints/:id/history",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/checkpoints/{{checkpointId}}/history?page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "checkpoints",
                "{{checkpointId}}",
                "history"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('History endpoint success', function () {",
                  "  if (pm.response.code === 404) pm.expect.fail('404 on /history: checkpoint missing. Create checkpoint and update status first.');",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE /api/v1/checkpoints/:id (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/checkpoints/{{checkpointId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "checkpoints",
                "{{checkpointId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Delete checkpoint success', function () {",
                  "  if (pm.response.code === 403) pm.expect.fail('403 Access denied on delete. Ensure admin role and fresh login token.');",
                  "  if (pm.response.code === 404) pm.expect.fail('404 on delete. Checkpoint was already deleted.');",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
