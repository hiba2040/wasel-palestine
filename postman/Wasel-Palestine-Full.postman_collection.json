    {
      "name": "05 - Routes Real Integration",
      "item": [
        {
          "name": "GET /api/v1/routes/estimate",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/routes/estimate?sourceLat={{sourceLat}}&sourceLon={{sourceLon}}&destLat={{destLat}}&destLon={{destLon}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "routes",
                "estimate"
              ],
              "query": [
                {
                  "key": "sourceLat",
                  "value": "{{sourceLat}}"
                },
                {
                  "key": "sourceLon",
                  "value": "{{sourceLon}}"
                },
                {
                  "key": "destLat",
                  "value": "{{destLat}}"
                },
                {
                  "key": "destLon",
                  "value": "{{destLon}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const status = pm.response.code;",
                  "pm.test('Estimate status is 200 or 503', function () {",
                  "  pm.expect([200, 503]).to.include(status);",
                  "});",
                  "const json = pm.response.json();",
                  "if (status === 200) {",
                  "  pm.test('Estimate success true', function () { pm.expect(json.success).to.eql(true); });",
                  "  pm.test('Distance is numeric', function () { pm.expect(json.data.route.distance).to.be.a('number'); });",
                  "  pm.test('Weather condition exists', function () { pm.expect(json.data.weather.condition).to.be.a('string'); });",
                  "  pm.test('Safety score exists', function () { pm.expect(json.data.safety.score).to.be.a('number'); });",
                  "} else {",
                  "  pm.test('503 has external-service message', function () {",
                  "    pm.expect(json.success).to.eql(false);",
                  "    pm.expect(json.message).to.eql('external service unavailable');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /api/v1/routes/analyze",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/routes/analyze?sourceLat={{sourceLat}}&sourceLon={{sourceLon}}&destLat={{destLat}}&destLon={{destLon}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "routes",
                "analyze"
              ],
              "query": [
                {
                  "key": "sourceLat",
                  "value": "{{sourceLat}}"
                },
                {
                  "key": "sourceLon",
                  "value": "{{sourceLon}}"
                },
                {
                  "key": "destLat",
                  "value": "{{destLat}}"
                },
                {
                  "key": "destLon",
                  "value": "{{destLon}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const status = pm.response.code;",
                  "pm.test('Analyze status is 200 or 503', function () {",
                  "  pm.expect([200, 503]).to.include(status);",
                  "});",
                  "const json = pm.response.json();",
                  "if (status === 200) {",
                  "  pm.test('Analyze success true', function () { pm.expect(json.success).to.eql(true); });",
                  "  pm.test('Routes array returned', function () { pm.expect(json.data.routes).to.be.an('array'); });",
                  "} else {",
                  "  pm.test('Analyze external service message', function () {",
                  "    pm.expect(json.success).to.eql(false);",
                  "    pm.expect(json.message).to.eql('external service unavailable');",
                  "  });",
                  "}"
                ]
              }
            }
          ]
