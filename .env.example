# ==================================
# Wasel Palestine API - Environment Variables
# ==================================

# ==== NODE ENVIRONMENT ====
NODE_ENV=development
PORT=3000

# ==== DATABASE (PostgreSQL) ====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wasel_db
DB_USER=wasel_user
DB_PASSWORD=wasel_password

# ==== REDIS CACHE ====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_ENABLED=true

# ==== JWT AUTHENTICATION ====
JWT_SECRET=your_super_secret_jwt_key_12345
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_key_12345
JWT_REFRESH_EXPIRES_IN=30d

# ==== CACHING TTL (in seconds) ====
ROUTE_CACHE_TTL=3600
WEATHER_CACHE_TTL=1800
CHECKPOINT_CACHE_TTL=300
DEFAULT_CACHE_TTL=600

# ==== EXTERNAL APIs ====
OPENROUTESERVICE_API_KEY=your_actual_openroute_api_key_here
OPENROUTESERVICE_BASE_URL=https://api.openrouteservice.org/v2/directions/driving-car
OPENWEATHER_API_KEY=your_actual_openweather_api_key_here
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ==== FEATURE FLAGS ====
MOCK_API_ENABLED=false
ROUTE_ESTIMATION_ENABLED=true
