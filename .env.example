# ==================================
# Wasel Palestine API - Environment Variables
# ==================================

# ==== NODE ENVIRONMENT ====
NODE_ENV=development
PORT=3000

# ==== DATABASE (PostgreSQL) ====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wasel_db
DB_USER=wasel_user
DB_PASSWORD=wasel_password

# ==== REDIS CACHE ====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_ENABLED=true

# ==== JWT AUTHENTICATION ====
# Generate strong secrets in production: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# ==== CACHING TTL (in seconds) ====
ROUTE_CACHE_TTL=3600           # Route estimates: 1 hour
WEATHER_CACHE_TTL=1800         # Weather data: 30 minutes
CHECKPOINT_CACHE_TTL=300       # Checkpoint status: 5 minutes
DEFAULT_CACHE_TTL=600          # Default cache: 10 minutes

# ==== EXTERNAL ROUTE & WEATHER APIS ====
OPENROUTESERVICE_API_KEY=your_openrouteservice_api_key
OPENROUTESERVICE_BASE_URL=https://api.openrouteservice.org/v2/directions/driving-car
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ==== FEATURE FLAGS ====
MOCK_API_ENABLED=true
ROUTE_ESTIMATION_ENABLED=true

# ==== DOCKER-SPECIFIC (for docker-compose) ====
# When running in Docker, these are set in docker-compose.yml
# POSTGRES_USER=wasel_user
# POSTGRES_PASSWORD=wasel_password
# POSTGRES_DB=wasel_db
